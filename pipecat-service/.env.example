# LiveKit (WebRTC)
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit Egress -> Supabase Storage (S3-compatible)
LIVEKIT_EGRESS_S3_ACCESS_KEY=
LIVEKIT_EGRESS_S3_SECRET_KEY=
LIVEKIT_EGRESS_S3_REGION=us-east-1
LIVEKIT_EGRESS_S3_ENDPOINT=
LIVEKIT_EGRESS_S3_BUCKET=session-recordings
LIVEKIT_EGRESS_S3_FORCE_PATH_STYLE=true

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=

# Cartesia (Text-to-Speech)
CARTESIA_API_KEY=

# OpenRouter (LLM)
OPENROUTER_API_KEY=
CONVERSATION_MODEL=x-ai/grok-4.1-fast
CONVERSATION_FALLBACK_MODEL=google/gemini-3-flash-preview
ANALYSIS_MODEL=anthropic/claude-opus-4.6

# Supabase (service role access)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Recording persistence
RECORDING_ENABLED=true
RECORDING_BUCKET=session-recordings
RECORDING_RETENTION_DAYS=30

# API Auth (must match frontend PIPECAT_SERVICE_API_KEY)
PIPECAT_SERVICE_API_KEY=
