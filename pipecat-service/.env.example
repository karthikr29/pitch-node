# LiveKit (WebRTC)
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=

# Cartesia (Text-to-Speech)
CARTESIA_API_KEY=

# OpenRouter (LLM)
OPENROUTER_API_KEY=
CONVERSATION_MODEL=x-ai/grok-4.1-fast
CONVERSATION_FALLBACK_MODEL=google/gemini-3-flash-preview
ANALYSIS_MODEL=anthropic/claude-opus-4.6

# Supabase (service role access)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API Auth (must match frontend PIPECAT_SERVICE_API_KEY)
PIPECAT_SERVICE_API_KEY=
