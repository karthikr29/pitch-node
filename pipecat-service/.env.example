# ─────────────────────────────────────────────────────────────────
# ConvoSparr Pipecat Service — Environment Variables
# ─────────────────────────────────────────────────────────────────

# LiveKit
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=<livekit-api-key>
LIVEKIT_API_SECRET=<livekit-api-secret>

# Deepgram STT
DEEPGRAM_API_KEY=<deepgram-api-key>
DEEPGRAM_STT_MODEL=flux-general-en
DEEPGRAM_FALLBACK_STT_MODEL=nova-3-general
# Set to true to hard-require Flux model (no fallback). Default: false.
DEEPGRAM_FLUX_REQUIRED=false

# Cartesia TTS
CARTESIA_API_KEY=<cartesia-api-key>
CARTESIA_MODEL=sonic-3
CARTESIA_MAX_BUFFER_DELAY_MS=0

# OpenRouter (used for conversation LLM, role inference, and analysis)
OPENROUTER_API_KEY=<openrouter-api-key>

# LLM model configuration
CONVERSATION_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
CONVERSATION_FALLBACK_MODEL=google/gemini-3-flash-preview
ANALYSIS_MODEL=moonshotai/kimi-k2.5
INFER_ROLE_MODEL=google/gemini-2.5-flash-lite-preview-09-2025

# Voice pipeline tuning (safe to leave at defaults)
VOICE_USE_EAGER_EOT=true
VOICE_EAGER_EOT_THRESHOLD=0.35
VOICE_EOT_THRESHOLD=0.5
VOICE_EOT_TIMEOUT_MS=700
VOICE_CONTEXT_MAX_TURNS=4
VOICE_TTS_FIRST_CHUNK_TOKENS=8
VOICE_TTS_FIRST_CHUNK_MIN_TOKENS=4
VOICE_TTS_FIRST_CHUNK_MAX_WAIT_MS=250
VOICE_TTS_SUBSEQUENT_CHUNK_TOKENS=8

# Supabase (service role — bypasses RLS for session/transcript writes)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Auth — shared secret between Next.js and this service. Must match PIPECAT_SERVICE_API_KEY in the frontend .env.
PIPECAT_SERVICE_API_KEY=<shared-secret>

# Sentry error monitoring
# Use the Pipecat-specific DSN from https://convosparr.sentry.io/projects/convosparr-pipecat/
# This is a DIFFERENT DSN from the Next.js project.
SENTRY_DSN=https://<key>@o<org>.ingest.de.sentry.io/<pipecat-project-id>

# CORS — comma-separated list of allowed frontend origins.
# Set to your Vercel production URL and any preview URLs.
# For local dev: http://localhost:3000
ALLOWED_ORIGINS=https://convosparr.com,https://<preview>.vercel.app

# Server
APP_DEBUG=false
LOG_LEVEL=INFO
#PORT=8000
