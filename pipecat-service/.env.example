LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=flux-general-en
DEEPGRAM_FALLBACK_STT_MODEL=nova-3-general
DEEPGRAM_FLUX_REQUIRED=false
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-3
CARTESIA_MAX_BUFFER_DELAY_MS=0
OPENROUTER_API_KEY=
XAI_API_KEY=
XAI_API_BASE_URL=https://api.x.ai/v1
CONVERSATION_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
CONVERSATION_FALLBACK_MODEL=google/gemini-3-flash-preview
ANALYSIS_MODEL=moonshotai/kimi-k2.5
INFER_ROLE_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
VOICE_USE_EAGER_EOT=true
VOICE_EAGER_EOT_THRESHOLD=0.35
VOICE_EOT_THRESHOLD=0.5
VOICE_EOT_TIMEOUT_MS=700
VOICE_CONTEXT_MAX_TURNS=4
VOICE_TTS_FIRST_CHUNK_TOKENS=8
VOICE_TTS_FIRST_CHUNK_MIN_TOKENS=4
VOICE_TTS_FIRST_CHUNK_MAX_WAIT_MS=250
VOICE_TTS_SUBSEQUENT_CHUNK_TOKENS=8

# --- VAD (Silero) tuning. stop_secs is adaptive: quiet rooms keep latency low,
# noisy rooms wait longer to confirm end-of-turn so fan/HVAC noise doesn't
# re-trigger speech start. Noisy mode triggers when 1s rolling RMS >= NOISE_DETECT_RMS.
VAD_CONFIDENCE=0.85
VAD_START_SECS=0.3
VAD_STOP_SECS_QUIET=0.2
VAD_STOP_SECS_NOISY=0.4
VAD_MIN_VOLUME=0.7
VAD_NOISE_DETECT_RMS=0.012

# --- Drop final transcripts whose Deepgram confidence is below this floor.
STT_MIN_AVG_WORD_CONFIDENCE=0.55

# --- Speaker verification (Resemblyzer). Voiceprint is captured per-call and
# never persisted. Lenient_short_segments accepts <1s utterances (e.g. "yeah");
# off by default to be strict.
VERIFICATION_SIMILARITY_THRESHOLD=0.70
VERIFICATION_WINDOW_MS=1500
VERIFICATION_MIN_AUDIO_SECS=1.0
VERIFICATION_LENIENT_SHORT_SEGMENTS=false
VERIFICATION_DECISION_DEADLINE_MS=250

# --- Voiceprint enrollment (POST /api/v1/voiceprint/enroll).
VOICEPRINT_ENROLL_MAX_AUDIO_BYTES=400000
VOICEPRINT_ENROLL_MIN_DURATION_MS=2000
VOICEPRINT_ENROLL_MAX_DURATION_MS=8000

# --- Sustained-rejection AI cue + auto-end (in seconds of consecutive drops).
REJECTION_CUE_THRESHOLD_SECS=12.0
REJECTION_AUTO_END_THRESHOLD_SECS=32.0

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PIPECAT_SERVICE_API_KEY=
# Sentry error monitoring (FastAPI-specific DSN — NOT the same as the Next.js DSN)
# Generate from: https://convosparr.sentry.io/projects/convosparr-pipecat/
SENTRY_DSN=
#PORT=8000