# LiveKit (WebRTC)
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=

# Cartesia (Text-to-Speech)
CARTESIA_API_KEY=

# OpenRouter (LLM)
OPENROUTER_API_KEY=
CONVERSATION_MODEL=meta-llama/llama-3.1-70b-instruct
ANALYSIS_MODEL=anthropic/claude-3.5-sonnet

# Supabase (service role access)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API Auth (must match frontend PIPECAT_SERVICE_API_KEY)
PIPECAT_SERVICE_API_KEY=
