# ─────────────────────────────────────────────────────────────────
# ConvoSparr — Environment Variables
# Copy to .env.local for local development.
# In Vercel: set per-environment (Production vs Preview vs Development).
# ─────────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
# Server-only. Never expose to the browser. Used by admin client and API routes.
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# LiveKit
NEXT_PUBLIC_LIVEKIT_URL=wss://<project>.livekit.cloud

# Voice Pipeline (Pipecat backend)
# In production: must be the deployed Railway URL (e.g. https://your-service.up.railway.app).
# Locally: if omitted, defaults to http://localhost:8000.
PIPECAT_SERVICE_URL=https://<railway-service>.up.railway.app
# Shared secret between Next.js and Pipecat. Must match PIPECAT_SERVICE_API_KEY in the backend .env.
PIPECAT_SERVICE_API_KEY=<shared-secret-with-pipecat-service>

# App Environment
# IMPORTANT: Must be set to "production" in Vercel Production environment.
# When set to "development", Sentry is fully disabled and some safety checks are relaxed.
NEXT_PUBLIC_APP_ENV=development

# Auth redirect URL
# Required in Vercel deployments. Set to https://convosparr.io for production.
# For preview deployments: set to the preview URL. Locally: http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry error monitoring
# Use the Next.js-specific DSN from https://convosparr.sentry.io/projects/convosparr/
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.de.sentry.io/<project-id>
SENTRY_DSN=https://<key>@o<org>.ingest.de.sentry.io/<project-id>
SENTRY_ORG=convosparr
SENTRY_PROJECT=convosparr
# SENTRY_AUTH_TOKEN is required only at build time for source map uploads (CI/CD or Vercel build step).
# Do not commit this value. Set it in your CI environment or Vercel build settings.
# SENTRY_AUTH_TOKEN=<sentry-auth-token>
