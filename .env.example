# Copy this file to .env.local for local development.
# In Vercel, configure these values per environment (Production vs Preview).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side webhook endpoint used after waitlist submissions.
# Leave empty in preview if you want to skip webhook side effects.
WAITLIST_WEBHOOK_URL=

# development | preview | production
NEXT_PUBLIC_APP_ENV=development
