# Copy this file to .env.local for local development.
# In Vercel, configure these values per environment (Production vs Preview).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LiveKit
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Voice Pipeline (Pipecat backend)
PIPECAT_SERVICE_URL=http://localhost:8000
PIPECAT_SERVICE_API_KEY=

# App Environment
NEXT_PUBLIC_APP_ENV=development

# Auth redirect URL (set in Vercel, not needed locally)
NEXT_PUBLIC_SITE_URL=

# Waitlist (optional)
WAITLIST_WEBHOOK_URL=

# Sentry error monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN is only needed in CI/CD for source map uploads. Do not commit.
# SENTRY_AUTH_TOKEN=
